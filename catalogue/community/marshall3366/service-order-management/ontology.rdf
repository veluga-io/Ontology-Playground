<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/service-order-management/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/service-order-management/">

    <owl:Ontology rdf:about="http://example.org/ontology/service-order-management/">
        <rdfs:label>Service Order Management</rdfs:label>
        <rdfs:comment>Service Order Management</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-10">
        <rdfs:label>Warehouse</rdfs:label>
        <rdfs:comment>It tells the location of each warehouse/plant where the part is being kept and the inventory level information</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-9">
        <rdfs:label>ServiceEngineer</rdfs:label>
        <rdfs:comment>Service orders are the parts or devices which requires installation and service engineer needs to inspect the site and do the installation</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-8">
        <rdfs:label>Payment</rdfs:label>
        <rdfs:comment>This a payment table and contains info about Payment method, Amount, Payment Status &amp; Transaction ID</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-7">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>It contains details regarding Courier type, Courier Service Name, Delivery Date, Dispatch Date, Delivery Status, Customer Name</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-6">
        <rdfs:label>Parts</rdfs:label>
        <rdfs:comment>Parts/Product related information like Product category, Brand and the Retail Price</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-5">
        <rdfs:label>SalesTarget</rdfs:label>
        <rdfs:comment>Monthly Sales target by each product ID</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-4">
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>It has details regarding the Customer Name (people) and the region from which they ordered</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-3">
        <rdfs:label>Return</rdfs:label>
        <rdfs:comment>Devices that got returned by Customers</rdfs:comment>
        <ont:icon>🛒</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/service-order-management/New-entity-2">
        <rdfs:label>ServiceOrders</rdfs:label>
        <rdfs:comment>Orders placed by the customers, Products details, Shipment details, Sales Amount</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

