    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-27">
        <rdfs:label>results_in</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-13"/>
        <rdfs:comment>Captures the closure / solving solution of an incident. The Incident event only captures the moment.</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-13</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-26">
        <rdfs:label>Sits_in</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-8"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-7"/>
        <rdfs:comment>During an incident 1 or more firefighters are driving in a vehicle. </rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-8</ont:fromEntityId>
        <ont:toEntityId>new-entity-7</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-24">
        <rdfs:label>occurs_at</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-12"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-10"/>
        <rdfs:comment>An event happens at a location</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-12</ont:fromEntityId>
        <ont:toEntityId>new-entity-10</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-23">
        <rdfs:label>relates_to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-12"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-6"/>
        <rdfs:comment>Mulitple events belong to the same response unit. like: 


Unit_initiating_time = Dispatcher assigns response unit
Unit_departure_time = Response unit leaves fire station
Unit_incident_arrival_time = Response unit arrives at incident
Unit_return_time = Response unit leaves incident 
Unit_station_arrival_time = 
Response unit arrives back at fire station</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-12</ont:fromEntityId>
        <ont:toEntityId>new-entity-6</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-22">
        <rdfs:label>has</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-12"/>
        <rdfs:comment>An Incident has multiple Events related in time</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-12</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-21">
        <rdfs:label>is_based_at_a</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-8"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-11"/>
        <rdfs:comment>A firefighter is based at a fire station.</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-8</ont:fromEntityId>
        <ont:toEntityId>new-entity-11</ont:toEntityId>
