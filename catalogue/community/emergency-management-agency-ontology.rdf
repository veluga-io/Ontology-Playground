        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-4"/>
        <rdfs:comment>A dispatcher is located at a specific dispatch location</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-5</ont:fromEntityId>
        <ont:toEntityId>new-entity-4</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-13">
        <rdfs:label>is_staffed_by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-8"/>
        <rdfs:comment>A firefighter is part of the response unit, together with other firefighters in a vehicle</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-6</ont:fromEntityId>
        <ont:toEntityId>new-entity-8</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-12">
        <rdfs:label>Reports_to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-1"/>
        <rdfs:comment>1 or more response unit can be dispatched to an incident, and therefore the report to the incident</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-6</ont:fromEntityId>
        <ont:toEntityId>new-entity-1</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-11">
        <rdfs:label>Uses</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-7"/>
        <rdfs:comment>A responce unit drives / uses a vehicle</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-6</ont:fromEntityId>
        <ont:toEntityId>new-entity-7</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-9">
        <rdfs:label>Dispatches</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-6"/>
        <rdfs:comment>A dispatcher dispatches the response unit for the incident. there can be more units being dispatched.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-5</ont:fromEntityId>
        <ont:toEntityId>new-entity-6</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-8">
        <rdfs:label>Asseses</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-1"/>
        <rdfs:comment>A dispatcher asseses the incident</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-5</ont:fromEntityId>
        <ont:toEntityId>new-entity-1</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-5">
        <rdfs:label>Receives</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-3"/>
        <rdfs:comment>a specific Dispatcher at a Dispatch center receives the emergency call</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-5</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-3">
        <rdfs:label>Handles</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-3"/>
        <rdfs:comment>A dispatch center handles 1 or more emergency calls</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-2">
        <rdfs:label>Reports</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-1"/>
        <rdfs:comment>An emergency call reports an incident. There can be more calls for the same incident</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-3</ont:fromEntityId>
        <ont:toEntityId>new-entity-1</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/emergency-management-agency-ontology/rel-relates-to-1">
        <rdfs:label>initiates</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://example.org/ontology/emergency-management-agency-ontology/New-entity-3"/>
        <rdfs:comment>A Caller reports the incident with an emergency call</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-2</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
