<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/emergency-management-agency-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/emergency-management-agency-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/emergency-management-agency-ontology/">
        <rdfs:label>Emergency Management Agency ontology</rdfs:label>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-13">
        <rdfs:label>Incident_Resolution</rdfs:label>
        <rdfs:comment>This represents how and why the incident was closed / solved.

Incident resolution is modeled explicitly through incident events and a resolution concept, allowing the ontology to capture not only when an incident ends, but also why and by whom it was resolved.</rdfs:comment>
        <ont:icon>🔗</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-12">
        <rdfs:label>Incident_Event</rdfs:label>
        <rdfs:comment>Represents all the time events happening on the incident.

Note that Incident_Event updates Incident_Classification</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-11">
        <rdfs:label>Fire_Station</rdfs:label>
        <rdfs:comment>A location where fire vehicles and firefighters are located and togther they form a response unit</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-10">
        <rdfs:label>Location</rdfs:label>
        <rdfs:comment>location or area type of incident</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-9">
        <rdfs:label>Incident_Classification</rdfs:label>
        <rdfs:comment>Specifies</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-8">
        <rdfs:label>Firefighter</rdfs:label>
        <rdfs:comment>Represents an individual responder.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-7">
        <rdfs:label>Vehicle</rdfs:label>
        <rdfs:comment>A fire department vehicle</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-6">
        <rdfs:label>Response_Unit</rdfs:label>
        <rdfs:comment>Represents a deployable fire department resource unit</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-5">
        <rdfs:label>Dispatcher</rdfs:label>
        <rdfs:comment>Represents the individual assessing emergency call; calls and initiating responses.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-4">
        <rdfs:label>Dispatch_Center</rdfs:label>
        <rdfs:comment>Represents the organizational unit handling intake, assessment, and coordination.</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-3">
        <rdfs:label>Emergency_Call</rdfs:label>
        <rdfs:comment>Represents the initial report that triggers the incident lifecycle.</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-2">
        <rdfs:label>Caller</rdfs:label>
        <rdfs:comment>Represents the person or system reporting the incident.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/emergency-management-agency-ontology/New-entity-1">
        <rdfs:label>Incident</rdfs:label>
        <rdfs:comment>Represents a single emergency situation requiring fire department involvement.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

