    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/places">
        <rdfs:label>places</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Customer"/>
        <rdfs:range rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Order"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>customer</ont:fromEntityId>
        <ont:toEntityId>order</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/hasAddress">
        <rdfs:label>has address</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Customer"/>
