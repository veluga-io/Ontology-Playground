        <rdfs:domain rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Invoice"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>invoice</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/recordedAt">
        <rdfs:label>recorded at</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/PointOfSales"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>pointOfSales</ont:toEntityId>
    </owl:ObjectProperty>

