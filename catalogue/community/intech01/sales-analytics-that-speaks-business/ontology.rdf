<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/">
        <rdfs:label>Sales Analytics That Speaks Business—Using Fabric IQ Ontology</rdfs:label>
        <rdfs:comment>A Fabric IQ–powered sales ontology that turns transactional data into the language of the business — Customer places Order, Order generates Invoice, Return reduces Revenue — so leaders ask questions in plain business terms, not SQL.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Customer">
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>A person or organization that purchases goods or services from the company. Holds an address, maintains a balance, and engages in orders, invoices, and returns.</rdfs:comment>
        <ont:icon>🙋‍♂️</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/CustomerAddress">
        <rdfs:label>Customer Address</rdfs:label>
        <rdfs:comment>A physical or mailing location associated with a customer, used for billing and delivery.</rdfs:comment>
        <ont:icon>🏠</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Item">
        <rdfs:label>Item</rdfs:label>
        <rdfs:comment>A product or service offered by the company. Can be ordered, stored in a warehouse, sold by a sales person, and transacted through a point of sale.</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Warehouse">
        <rdfs:label>Warehouse</rdfs:label>
        <rdfs:comment>A physical facility where items are stored, orders are fulfilled, and returns are processed. Owned and operated by the company.</rdfs:comment>
        <ont:icon>🏭</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Department">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>An internal organizational unit that groups sales personnel, sits within a company, and contributes to overall revenue.</rdfs:comment>
        <ont:icon>🏛️</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/SalesPerson">
        <rdfs:label>Sales Person</rdfs:label>
        <rdfs:comment>An employee who handles customer orders, sells items, works within a department, and is evaluated through sales performance.</rdfs:comment>
        <ont:icon>💼</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Company">
        <rdfs:label>Company</rdfs:label>
        <rdfs:comment>The legal business entity that owns warehouses, operates points of sale, and employs sales personnel.</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Order">
        <rdfs:label>Order</rdfs:label>
        <rdfs:comment>A request placed by a customer to purchase one or more items. Fulfilled from a warehouse, handled by a sales person, recorded at a point of sale, and generates an invoice.</rdfs:comment>
        <ont:icon>🛒</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Invoice">
        <rdfs:label>Invoice</rdfs:label>
        <rdfs:comment>A billing document generated from an order and issued to a customer. Records the amount payable and contributes to revenue.</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Return">
        <rdfs:label>Return</rdfs:label>
        <rdfs:comment>A transaction in which a customer sends back items from a prior order. Processed at a warehouse and reduces recognized revenue.</rdfs:comment>
        <ont:icon>🚚</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/CustomerBalance">
        <rdfs:label>Customer Balance</rdfs:label>
        <rdfs:comment>The current outstanding monetary amount owed by, or credit held for, a customer at a given point in time.</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/SalesPerformance">
        <rdfs:label>Sales Performance</rdfs:label>
        <rdfs:comment>A measure of a sales person&apos;s effectiveness over a period, evaluated in terms of revenue achieved.</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Revenue">
        <rdfs:label>Revenue</rdfs:label>
        <rdfs:comment>The total monetary income recognized by the business, generated through invoices, departments, and points of sale, and reduced by returns.</rdfs:comment>
        <ont:icon>💵</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/PointOfSales">
        <rdfs:label>Point of Sales</rdfs:label>
        <rdfs:comment>A location or terminal where sales transactions are completed and recorded. Operated by the company and generates revenue.</rdfs:comment>
        <ont:icon>💰</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/customer_customerId">
        <rdfs:label>customerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

