        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>salesPerson</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/sales-analytics-that-speaks-businessusing-fabric-iq-ontology/generatesInvoice">
